# Server-only Gemini credentials. Copy this file to .env.local.
# Never use a VITE_ prefix for the API key and never commit .env.local.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Local AI service settings
AI_HOST=127.0.0.1
AI_PORT=8787
AI_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
AI_TRUST_PROXY=false

# Admin dashboard (server-only). Generate safe values with: npm run admin:secrets
AURORA_ADMIN_PASSWORD_SHA256=
AURORA_ADMIN_SESSION_SECRET=

# Persistent catalogue storage. Vercel Marketplace / Upstash sets one pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Local-only testing. Never enable this for production serverless deployments.
AURORA_ALLOW_MEMORY_STORAGE=false

# Full-site local preview after `npm run build`
SITE_HOST=127.0.0.1
SITE_PORT=4173
